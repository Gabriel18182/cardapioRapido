<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView
        android:id="@+id/textNomeMesa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_weight="1"
        android:fontFamily="@font/opensans_semibolditalic"
        android:textColor="@color/gray_dark"
        android:textSize="20sp" />

    <Button
        android:id="@+id/buttonCompartilharMesa"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/button_item"
        android:contentDescription="Gerar QR Code da mesa"
        android:drawableTop="@drawable/ic_qr_code"
        android:padding="8dp" />

    <Button
        android:id="@+id/buttonAlterarMesa"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/button_item"
        android:contentDescription="Alterar mesa"
        android:drawableTop="@drawable/icon_alterar"
        android:padding="8dp" />

    <Button
        android:id="@+id/buttonDeletarMesa"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/button_item"
        android:contentDescription="Deletar mesa"
        android:drawableTop="@drawable/icon_remover"
        android:padding="8dp" />
</LinearLayout>
